# Drizzle — must match your Postgres (user, password, host port, database).
#
# Optional: RoSvelte compose.yaml (localhost:5432) — postgres://root:root@localhost:5432/rosvelte
#
# Shared stack postgres-iatweb (~/Docker/general/iatweb): published as localhost:5434, root/root,
# default DB iatwebdb. Prefer a dedicated DB for this app, e.g. rosvelte:
#   psql "postgres://root:root@localhost:5434/postgres" -c "CREATE DATABASE rosvelte;"
# Then:
DATABASE_URL="postgres://root:root@localhost:5434/rosvelte"

# Apply tables (Better Auth + app). drizzle.config loads .env automatically.
#   npm run db:push
# If push fails, apply the same shape manually:
#   psql "$DATABASE_URL" -f drizzle/init-db.sql

# App origin for Better Auth (callbacks, CSRF). Must match the URL you open in the browser, e.g.:
# ORIGIN="http://rosvelte.test"
# or: BETTER_AUTH_URL="http://rosvelte.test"
ORIGIN=""
BETTER_AUTH_URL=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# Separate secret for storefront-only auth (customers table). If unset, BETTER_AUTH_SECRET is used.
BETTER_AUTH_CUSTOMER_SECRET=""
# Staff vs customer: two instances — staff cookies `rosvelte-staff.*`, customer `rosvelte-customer.*`; API paths `/api/auth` and `/api/customer-auth`.
# Customer password reset: until you wire email, the reset URL is logged to the server console.

# Superstore (staff UI at /superstore). If neither allowlist nor allow-any is set, signed-in users get 403.
# Comma-separated emails allowed (after sign-in). Example: you@company.com,other@company.com
SUPERSTORE_ALLOWED_EMAILS=""
# Local dev: set to true (or 1 / yes) so any signed-in user can open /superstore. Restart dev server after changing.
# Production: keep false and use SUPERSTORE_ALLOWED_EMAILS only.
SUPERSTORE_ALLOW_ANY_AUTHENTICATED_USER="false"
# Where uploaded files are stored (relative to project root)
SUPERSTORE_UPLOAD_DIR=".data/superstore-uploads"
# Max upload size in MB (capped at 50 in code)
SUPERSTORE_MAX_UPLOAD_MB="10"
