{
	"name": "rosvelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:host": "VITE_DEV_HOST=rosvelte.test vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:seed:catalog": "tsx scripts/seed-catalog.ts",
		"db:seed:journal": "tsx scripts/seed-journal.ts",
		"db:seed:orders": "tsx scripts/seed-orders.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@chromatic-com/storybook": "^5.1.2",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.15.2",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.6",
		"@storybook/addon-docs": "^10.3.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.6",
		"@storybook/sveltekit": "^10.3.6",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.3",
		"@vitest/coverage-v8": "^4.1.3",
		"better-auth": "~1.4.21",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.3.6",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.59.1",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.6",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"@tanstack/table-core": "^8.21.3",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"tailwind-variants": "^3.2.2",
		"xendit-node": "^7.0.0",
		"xlsx": "^0.18.5",
		"zod": "^4.4.3"
	}
}
